{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jewzaam/claude-skill-review/schemas/agent-output.schema.json",
  "title": "Agent Output",
  "description": "JSON contract returned by a single review sub-agent for one (concern, dimension) cell.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "concern",
    "concern_slug",
    "dimension_name",
    "dimension_slug",
    "dimension_scope",
    "findings"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "concern": {
      "type": "string",
      "enum": [
        "Architecture & Design",
        "Implementation Quality",
        "Test Quality & Coverage",
        "Maintainability & Standards",
        "Security",
        "Documentation",
        "Observability"
      ]
    },
    "concern_slug": {
      "type": "string",
      "enum": [
        "architecture",
        "implementation",
        "test",
        "maintainability",
        "security",
        "documentation",
        "observability"
      ]
    },
    "dimension_name": {
      "type": "string",
      "minLength": 1
    },
    "dimension_slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,30}$"
    },
    "dimension_scope": {
      "type": "object",
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {"$ref": "#/$defs/finding"}
    },
    "cross_cutting_observations": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "impact",
        "likelihood",
        "effort_to_fix",
        "confidence",
        "locations",
        "issue",
        "why_it_matters",
        "suggested_fix"
      ],
      "properties": {
        "title": {"type": "string", "minLength": 1, "maxLength": 120},
        "impact": {"type": "integer", "minimum": 0, "maximum": 100},
        "likelihood": {"type": "integer", "minimum": 0, "maximum": 100},
        "effort_to_fix": {"type": "integer", "minimum": 0, "maximum": 100},
        "confidence": {"type": "integer", "minimum": 0, "maximum": 100},
        "locations": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/location"}
        },
        "issue": {"type": "string", "minLength": 1},
        "why_it_matters": {"type": "string", "minLength": 1},
        "suggested_fix": {"type": "string", "minLength": 1}
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "line"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "line": {"type": "string", "pattern": "^[0-9]+(-[0-9]+)?$"},
        "role": {
          "type": "string",
          "enum": ["primary", "related", "callsite", "requirement"]
        }
      }
    }
  }
}
