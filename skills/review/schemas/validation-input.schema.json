{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jewzaam/jewzaam-reviews/skills/review/schemas/validation-input.schema.json",
  "title": "Validation Input Batch",
  "description": "One batch of findings handed to a validator agent. Hard cap: 8 findings per batch.",
  "type": "object",
  "additionalProperties": false,
  "required": ["batch_number", "total_batches", "findings"],
  "properties": {
    "batch_number": {"type": "integer", "minimum": 1},
    "total_batches": {"type": "integer", "minimum": 1},
    "findings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {"$ref": "#/$defs/batch_finding"}
    }
  },
  "$defs": {
    "batch_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "content_hash", "concern_slug", "title", "impact", "likelihood", "effort_to_fix", "confidence", "locations", "issue", "why_it_matters", "suggested_fix"],
      "properties": {
        "index": {"type": "integer", "minimum": 0},
        "content_hash": {"type": "string", "pattern": "^[a-f0-9]{16,64}$"},
        "concern_slug": {"type": "string"},
        "title": {"type": "string"},
        "impact": {"type": "integer", "minimum": 0, "maximum": 100},
        "likelihood": {"type": "integer", "minimum": 0, "maximum": 100},
        "effort_to_fix": {"type": "integer", "minimum": 0, "maximum": 100},
        "confidence": {"type": "integer", "minimum": 0, "maximum": 100},
        "locations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "line"],
            "properties": {
              "path": {"type": "string"},
              "line": {"type": "string", "pattern": "^[0-9]+(-[0-9]+)?$"},
              "role": {"type": "string", "enum": ["primary", "related", "callsite", "requirement"]}
            }
          }
        },
        "issue": {"type": "string"},
        "why_it_matters": {"type": "string"},
        "suggested_fix": {"type": "string"}
      }
    }
  }
}
