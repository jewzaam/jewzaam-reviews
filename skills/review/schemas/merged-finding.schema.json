{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jewzaam/jewzaam-reviews/skills/review/schemas/merged-finding.schema.json",
  "title": "Merged Finding",
  "description": "A single finding file in a pipeline stage directory (10-merged/ or 20-findings/). Same shape as consolidated_finding but stored as an individual file keyed by content_hash filename.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "content_hash",
    "concern_slug",
    "source_dimensions",
    "title",
    "runtime_scope",
    "runtime_scope_justification",
    "failure_mode",
    "failure_mode_justification",
    "evidence_quality",
    "evidence_quality_justification",
    "trace_origin",
    "trace_origin_justification",
    "effort_to_fix",
    "effort_to_fix_justification",
    "locations",
    "issue",
    "why_it_matters",
    "suggested_fix"
  ],
  "properties": {
    "content_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{16,64}$",
      "description": "Stable 16-64 char hex SHA-256 prefix computed from (concern_slug, first contributor's dimension_slug, primary location path:line, title). Used as the filename and integrity key across pipeline stages."
    },
    "concern_slug": {
      "type": "string",
      "description": "Finding's concern axis.",
      "enum": [
        "architecture",
        "implementation",
        "test",
        "maintainability",
        "security",
        "documentation",
        "observability"
      ]
    },
    "source_dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"},
      "description": "Sorted union of dimension_slug values that contributed to this merged finding."
    },
    "title": {"type": "string", "minLength": 1, "maxLength": 120},
    "runtime_scope": {"$ref": "https://github.com/jewzaam/jewzaam-reviews/schemas/findings.schema.json#/$defs/runtime_scope"},
    "runtime_scope_justification": {"$ref": "https://github.com/jewzaam/jewzaam-reviews/schemas/findings.schema.json#/$defs/runtime_scope_justification"},
    "failure_mode": {"$ref": "https://github.com/jewzaam/jewzaam-reviews/schemas/findings.schema.json#/$defs/failure_mode"},
    "failure_mode_justification": {"$ref": "https://github.com/jewzaam/jewzaam-reviews/schemas/findings.schema.json#/$defs/failure_mode_justification"},
    "evidence_quality": {"$ref": "https://github.com/jewzaam/jewzaam-reviews/schemas/findings.schema.json#/$defs/evidence_quality"},
    "evidence_quality_justification": {"$ref": "https://github.com/jewzaam/jewzaam-reviews/schemas/findings.schema.json#/$defs/evidence_quality_justification"},
    "trace_origin": {"$ref": "https://github.com/jewzaam/jewzaam-reviews/schemas/findings.schema.json#/$defs/trace_origin"},
    "trace_origin_justification": {"$ref": "https://github.com/jewzaam/jewzaam-reviews/schemas/findings.schema.json#/$defs/trace_origin_justification"},
    "effort_to_fix": {"$ref": "https://github.com/jewzaam/jewzaam-reviews/schemas/findings.schema.json#/$defs/effort_to_fix"},
    "effort_to_fix_justification": {"$ref": "https://github.com/jewzaam/jewzaam-reviews/schemas/findings.schema.json#/$defs/effort_to_fix_justification"},
    "locations": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/location"}
    },
    "issue": {"type": "string", "minLength": 1},
    "why_it_matters": {"type": "string", "minLength": 1},
    "suggested_fix": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "line"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "line": {"type": "string", "pattern": "^[0-9]+(-[0-9]+)?$"},
        "role": {
          "type": "string",
          "enum": ["primary", "related", "callsite", "requirement"]
        }
      }
    }
  }
}
