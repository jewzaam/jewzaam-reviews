{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jewzaam/jewzaam-reviews/skills/review/schemas/validation-output.schema.json",
  "title": "Validation Output",
  "description": "Verdicts from one validator agent for one batch of findings.",
  "type": "object",
  "additionalProperties": false,
  "required": ["batch_number", "verdicts"],
  "properties": {
    "batch_number": {"type": "integer", "minimum": 1},
    "verdicts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/verdict"}
    }
  },
  "$defs": {
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_ref", "action", "reasoning"],
      "properties": {
        "finding_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": ["index", "content_hash"],
          "properties": {
            "index": {"type": "integer", "minimum": 0},
            "content_hash": {"type": "string", "pattern": "^[a-f0-9]{16,64}$"}
          }
        },
        "action": {"type": "string", "enum": ["confirm", "rescore", "remove"]},
        "new_scores": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "impact": {"type": "integer", "minimum": 0, "maximum": 100},
            "likelihood": {"type": "integer", "minimum": 0, "maximum": 100},
            "effort_to_fix": {"type": "integer", "minimum": 0, "maximum": 100},
            "confidence": {"type": "integer", "minimum": 0, "maximum": 100}
          }
        },
        "reasoning": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"action": {"const": "rescore"}}},
          "then": {"required": ["new_scores"]}
        },
        {
          "if": {"properties": {"action": {"enum": ["confirm", "remove"]}}},
          "then": {"not": {"required": ["new_scores"]}}
        }
      ]
    }
  }
}
