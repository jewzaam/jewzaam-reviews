{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jewzaam/jewzaam-reviews/schemas/findings.schema.json",
  "title": "Findings (cross-skill handoff)",
  "description": "Shared JSON shape emitted by producer skills (review, standards, c4-reverse-engineer) and consumer skill reports (apply-review). The document-level 'source' field discriminates which finding subtype is used and which top-level fields are required.",
  "type": "object",
  "required": ["schema_version", "source", "project", "findings", "issues"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "SemVer string, aligned with the plugin version at the time the document was written (.claude-plugin/plugin.json version). Consumers read this to identify which plugin release produced the envelope.",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-((0|[1-9][0-9]*|[0-9]*[a-zA-Z-][0-9a-zA-Z-]*)(\\.(0|[1-9][0-9]*|[0-9]*[a-zA-Z-][0-9a-zA-Z-]*))*))?(\\+([0-9a-zA-Z-]+(\\.[0-9a-zA-Z-]+)*))?$"
    },
    "source": {
      "description": "The producing skill, or the shape of the output for consumer skills. `update-pr` is absent deliberately — it emits review-shaped findings (with optional `pr_comment` fields) under `source: \"review\"`.",
      "enum": ["review", "standards", "c4-reverse-engineer", "apply-review"]
    },
    "project": {"$ref": "#/$defs/project"},
    "decomposition": {
      "type": "array",
      "items": {"$ref": "#/$defs/dimension"}
    },
    "findings": {"type": "array"},
    "issues": {
      "type": "array",
      "items": {"$ref": "#/$defs/issue"}
    },
    "applied": {
      "type": "array",
      "items": {"$ref": "#/$defs/applied_item"}
    },
    "supplementary": {
      "type": "object",
      "description": "Optional source-specific metadata that the render script uses to produce supplementary markdown. Not part of the cross-skill handoff contract; consumers may ignore it. Shape is defined by each producer skill."
    }
  },
  "unevaluatedProperties": false,
  "allOf": [
    {
      "if": {"properties": {"source": {"const": "review"}}, "required": ["source"]},
      "then": {
        "required": ["decomposition"],
        "properties": {
          "decomposition": {"minItems": 1},
          "findings": {"items": {"$ref": "#/$defs/review_finding"}}
        }
      }
    },
    {
      "if": {"properties": {"source": {"const": "standards"}}, "required": ["source"]},
      "then": {
        "properties": {
          "findings": {"items": {"$ref": "#/$defs/standards_finding"}}
        }
      }
    },
    {
      "if": {"properties": {"source": {"const": "c4-reverse-engineer"}}, "required": ["source"]},
      "then": {
        "properties": {
          "findings": {"items": {"$ref": "#/$defs/c4_finding"}}
        }
      }
    },
    {
      "if": {"properties": {"source": {"const": "apply-review"}}, "required": ["source"]},
      "then": {
        "required": ["applied"],
        "properties": {
          "findings": {"maxItems": 0}
        }
      }
    }
  ],
  "$defs": {
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "scope_slug": {"type": "string"}
      },
      "unevaluatedProperties": false
    },
    "dimension": {
      "type": "object",
      "required": ["dimension_name", "dimension_slug"],
      "properties": {
        "dimension_name": {"type": "string", "minLength": 1},
        "dimension_slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,30}$"},
        "dimension_scope": {"type": "object"}
      },
      "unevaluatedProperties": false
    },
    "location": {
      "type": "object",
      "required": ["path", "line"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "line": {"type": "string", "pattern": "^[0-9]+(-[0-9]+)?$"},
        "role": {"enum": ["primary", "related", "callsite", "requirement"]}
      },
      "unevaluatedProperties": false
    },
    "base_finding": {
      "type": "object",
      "required": [
        "id",
        "title",
        "severity",
        "locations",
        "issue",
        "why_it_matters",
        "suggested_fix",
        "content_hash"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[CISN][0-9]+$"},
        "title": {"type": "string", "minLength": 1, "maxLength": 120},
        "severity": {"enum": ["critical", "important", "suggestion", "needs-review"]},
        "locations": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/location"}
        },
        "issue": {"type": "string", "minLength": 1},
        "why_it_matters": {"type": "string", "minLength": 1},
        "suggested_fix": {"type": "string", "minLength": 1},
        "content_hash": {"type": "string", "pattern": "^[a-f0-9]{16,64}$"}
      }
    },
    "review_finding": {
      "allOf": [{"$ref": "#/$defs/base_finding"}],
      "required": [
        "concern_slug",
        "impact",
        "likelihood",
        "effort_to_fix",
        "confidence",
        "source_dimensions"
      ],
      "properties": {
        "concern_slug": {
          "enum": [
            "architecture",
            "implementation",
            "test",
            "maintainability",
            "security",
            "documentation",
            "observability"
          ]
        },
        "impact": {"type": "integer", "minimum": 0, "maximum": 100},
        "likelihood": {"type": "integer", "minimum": 0, "maximum": 100},
        "effort_to_fix": {"type": "integer", "minimum": 0, "maximum": 100},
        "confidence": {"type": "integer", "minimum": 0, "maximum": 100},
        "source_dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "pr_comment": {"$ref": "#/$defs/pr_comment"}
      },
      "unevaluatedProperties": false
    },
    "standards_finding": {
      "allOf": [{"$ref": "#/$defs/base_finding"}],
      "required": ["subdomain"],
      "properties": {
        "subdomain": {"type": "string", "minLength": 1}
      },
      "unevaluatedProperties": false
    },
    "c4_finding": {
      "allOf": [{"$ref": "#/$defs/base_finding"}],
      "required": ["artifact", "verdict", "spec_says", "code_says", "evidence"],
      "properties": {
        "artifact": {"type": "string", "minLength": 1},
        "verdict": {"enum": ["DISCREPANCY", "MISSING"]},
        "spec_says": {"type": "string", "minLength": 1},
        "code_says": {"type": "string", "minLength": 1},
        "evidence": {"type": "string", "minLength": 1}
      },
      "unevaluatedProperties": false
    },
    "issue": {
      "type": "object",
      "required": ["severity", "kind", "message"],
      "properties": {
        "severity": {"enum": ["error", "warning"]},
        "kind": {
          "enum": [
            "permission_denied",
            "subagent_failure",
            "validation_failed",
            "tool_unavailable",
            "schema_rejected_input",
            "other"
          ]
        },
        "message": {"type": "string", "minLength": 1},
        "source_component": {"type": "string", "minLength": 1},
        "context": {"type": "object"}
      },
      "unevaluatedProperties": false
    },
    "applied_item": {
      "type": "object",
      "required": ["finding_id", "outcome"],
      "properties": {
        "finding_id": {
          "type": "string",
          "pattern": "^[CISN][0-9]+$",
          "description": "Finding ID from the consumed Findings-*.json, e.g. C0, I3, S1."
        },
        "outcome": {
          "enum": ["applied", "skipped", "failed", "pending-commit"],
          "description": "applied = committed; skipped = no changes made; failed = attempted but errored; pending-commit = implemented in the working tree but left uncommitted (batch mode)."
        },
        "detail": {
          "type": "string",
          "description": "Short free-text note (e.g. reason for skip/fail, or a human-readable summary)."
        },
        "commit_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$",
          "description": "Commit SHA of the change produced by this finding. Required semantics: set when outcome is 'applied'; absent for skipped/failed/pending-commit."
        },
        "error_kind": {
          "enum": [
            "permission_denied",
            "subagent_failure",
            "validation_failed",
            "tool_unavailable",
            "schema_rejected_input",
            "other"
          ],
          "description": "Machine-readable error classification. Populated only when outcome is 'failed'; mirrors issue.kind so auditors can aggregate failures by cause."
        }
      },
      "allOf": [
        {
          "if": {"properties": {"outcome": {"const": "failed"}}, "required": ["outcome"]},
          "then": {"required": ["error_kind"]}
        }
      ],
      "unevaluatedProperties": false
    },
    "pr_comment": {
      "type": "object",
      "required": ["author", "id"],
      "properties": {
        "author": {"type": "string", "minLength": 1},
        "id": {"type": ["string", "integer"]},
        "url": {"type": "string"}
      },
      "unevaluatedProperties": false
    }
  }
}
